# Load this after the main .env when using compose.gpu.yaml.
AUTOML_GPU_IMAGE=managed-automl-api:0.7.0-cuda
AUTOML_GPU_TORCH_FIND_LINKS=https://download.pytorch.org/whl/cu130/torch/
AUTOML_GPU_TORCH_VERSION=2.13.0+cu130
AUTOML_TABPFN_DEVICE=cuda
NVIDIA_DRIVER_CAPABILITIES=compute,utility
NVIDIA_VISIBLE_DEVICES=all

# These are deliberately not accepted or populated by default. The operator
# must accept the applicable model-weight license and provide approved access.
AUTOML_TABPFN_LICENSE_ACCEPTED=false
AUTOML_TABPFN_MODEL_PATH=
TABPFN_TOKEN=
