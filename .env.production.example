# Production deployment template for Docker Compose or compatible secret injection.
# Copy to .env only in a protected deployment environment. Do not commit real .env files.
#
# Generate independent secrets with:
#   openssl rand -hex 32

AUTOML_AUTH_MODE=production
AUTOML_DEPLOYMENT_PROFILE=production
AUTOML_DOCKER_TARGET=production
AUTOML_JWT_ISSUER=https://identity.example.com/
AUTOML_JWT_AUDIENCE=managed-automl-api
AUTOML_JWT_KID=default
AUTOML_JWT_ALGORITHMS=RS256
AUTOML_JWT_LEEWAY_SECONDS=30

# Formal production uses OIDC/JWKS. Configure exactly one of AUTOML_JWKS_URL or
# AUTOML_JWKS_JSON. HS256 remains supported only for partner-preview deployments.
AUTOML_JWKS_URL=https://identity.example.com/.well-known/jwks.json
AUTOML_JWKS_JSON=
AUTOML_JWT_SECRET=
AUTOML_JWT_KEYS=

# These must be independent from JWT signing keys and from each other.
AUTOML_CURSOR_SECRET=
AUTOML_TICKET_SECRET=

# Metadata store and tenant isolation. The formal target intentionally remains unready until an
# external PostgreSQL/RLS adapter is wired into the service; setting this URL alone is not enough.
AUTOML_DATABASE_URL=postgresql://automl:change-me@postgres.example.internal:5432/automl
AUTOML_POSTGRES_RLS_REQUIRED=true

# Object storage and KMS. Use S3 or an S3-compatible service with server-side encryption.
AUTOML_OBJECT_STORE=s3
AUTOML_S3_BUCKET=managed-automl-artifacts
AUTOML_S3_ENDPOINT_URL=
AUTOML_KMS_KEY_ID=arn:aws:kms:us-east-1:111122223333:key/example
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Data-loss-prevention boundary for Agent context.
AUTOML_DLP_MODE=strict
AUTOML_AGENT_CONTEXT_FIELD_ALLOWLIST=run,objective,open_decision_packets,recent_output_refs,event_checkpoint,actions_href

# Production control-plane features.
AUTOML_WEBHOOK_DISPATCH_MODE=outbox
AUTOML_WEBHOOK_SIGNING_REQUIRED=true
AUTOML_DELETION_SAGA_ENABLED=true
AUTOML_MODEL_REGISTRY_MODE=enabled
AUTOML_WORKER_ISOLATION=container
AUTOML_REQUIRE_WORKER_ISOLATION=true

# Image and network. The Compose file binds to loopback by default; put a TLS/API gateway
# in front before any non-local exposure.
AUTOML_IMAGE=managed-automl-api:0.7.0
AUTOML_BIND_PORT=8000
AUTOML_LOG_LEVEL=info
AUTOML_PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
AUTOML_PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Framework runtime. Enable TabPFN only after model-weight license and checkpoint/token approval.
AUTOML_AUTOGLUON_TIME_LIMIT_SECONDS=20
AUTOML_BACKEND_WORK_DIR=/var/lib/automl/backend-work
AUTOML_TABPFN_DEVICE=cpu
AUTOML_TABPFN_LICENSE_ACCEPTED=false
AUTOML_TABPFN_MODEL_PATH=
TABPFN_TOKEN=

# Resource limits for the single-node profile.
AUTOML_CPU_LIMIT=2.0
AUTOML_MEMORY_LIMIT=4g
AUTOML_ML_THREADS=1
AUTOML_MAX_DATASET_BYTES=104857600
AUTOML_MAX_UPLOAD_PART_BYTES=104857600
AUTOML_MAX_ACTIVE_RUNS_PER_TENANT=4
AUTOML_MAX_STORAGE_BYTES_PER_TENANT=1073741824
AUTOML_MAX_TRIALS_PER_RUN=20
AUTOML_MAX_WALL_TIME_SECONDS=3600
AUTOML_MAX_COMPUTE_CREDITS=20
